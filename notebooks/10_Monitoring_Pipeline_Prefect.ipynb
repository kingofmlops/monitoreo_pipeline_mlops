   "cell_type": "markdown",
   "metadata": {"id": "step9"},
   "source": [\n",
    "## 9. Pipeline completo E2E (monitoreo integrado al pipeline base)\n",
    "\n",
    "Este flow combina el pipeline original (`mlops_pipeline`) con el monitoreo,\n",
    "de modo que tras cada ejecución de inferencia se lanza automáticamente el monitoreo.\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "full_e2e"},
   "source": [
    "import preprocessing as prep\n",
    "import inference as inf\n",
    "import posprocessing as posp\n",
    "\n",
    "@task(name='preprocess-data', log_prints=True)\n",
    "def preprocess_data(payload):\n",
    "    DIR_RAWDATA  = payload['DIR_RAWDATA']\n",
    "    DIR_PROCESSED = payload['DIR_PROCESSED']\n",
    "    partition_id = payload['params']['partition']\n",
    "    model_name   = payload['params']['model_name']\n",
    "    mode_type    = payload['params'].get('mode_type', 'inference')\n",
    "    print('Running preprocessing')\n",
    "    prep.main(model_name, DIR_RAWDATA, DIR_PROCESSED, mode_type, partition_id)\n",
    "    dir_pre  = f'{DIR_PROCESSED}/preprocessed/vars_{partition_id}_{model_name}.csv'\n",
    "    dir_post = f'{DIR_PROCESSED}/postprocessed/post_{partition_id}_{model_name}.csv'\n",
    "    return dir_pre, dir_post\n",
    "\n",
    "\n",
    "@task(name='run-inference', log_prints=True)\n",
    "def run_inference(payload, dir_pre_processed):\n",
    "    SCORE_DIR  = payload['SCORE_DIR']\n",
    "    MODEL_DIR  = payload['MODEL_DIR']\n",
    "    partition_id = payload['params']['partition']\n",
    "    model_name   = payload['params']['model_name']\n",
    "    print('Running inference')\n",
    "    inf.main(MODEL_DIR, dir_pre_processed, SCORE_DIR)\n",
    "    return f'{SCORE_DIR}/inference_{model_name}_{partition_id}.csv'\n",
    "\n",
    "\n",
    "@task(name='postprocess-results', log_prints=True)\n",
    "def postprocess_results(payload, dir_pos_processed, score_file_path):\n",
    "    DIR_OUTPUT = payload['DIR_OUTPUT']\n",
    "    print('Running postprocessing')\n",
    "    posp.main(dir_pos_processed, score_file_path, DIR_OUTPUT)\n",
    "\n",
    "\n",
    "@flow(name='mlops-pipeline-with-monitoring', log_prints=True)\n",
    "def mlops_pipeline_with_monitoring(payload):\n",
    "    \"\"\"\n",
    "    Pipeline E2E completo: inferencia + monitoreo integrado.\n",
    "    \"\"\"\n",
    "    print('\\n[E2E] Iniciando pipeline completo con monitoreo')\n",
    "\n",
    "    # ── 1. Pipeline base ──────────────────────────────────────────────────\n",
    "    dir_pre, dir_pos = preprocess_data(payload)\n",
    "    score_path = run_inference(payload, dir_pre_processed=dir_pre)\n",
    "    postprocess_results(payload, dir_pos_processed=dir_pos,\n",
    "                        score_file_path=score_path)\n",
    "    print('[E2E] ✅ Pipeline base completado')\n",
    "\n",
    "    # ── 2. Monitoreo ──────────────────────────────────────────────────────\n",
    "    print('[E2E] Iniciando pipeline de monitoreo...')\n",
    "    monitoring_results = monitoring_pipeline(payload)\n",
    "\n",
    "    return monitoring_results\n",
    "\n",
    "\n",
    "print('✅ Flow E2E completo definido: mlops_pipeline_with_monitoring')"
   ],
   "execution_count": null,
   "outputs": []
  },
