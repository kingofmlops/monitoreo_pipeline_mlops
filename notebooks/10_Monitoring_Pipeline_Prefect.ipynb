   "cell_type": "markdown",
   "metadata": {"id": "step1"},
   "source": ["## 1. Imports y configuración"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "imports"},
   "source": [
    "import os\n",
    "import glob\n",
    "import json\n",
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from multiprocessing import cpu_count\n",
    "from concurrent.futures import ProcessPoolExecutor, as_completed\n",
    "\n",
    "from prefect import flow, task\n",
    "from prefect.futures import wait\n",
    "\n",
    "import monitoring_utils as mon\n",
    "import preprocessing as prep\n",
    "import inference as inf\n",
    "import posprocessing as posp\n",
    "\n",
    "N_WORKERS = max(2, cpu_count() - 1)\n",
    "print(f'Workers disponibles: {N_WORKERS}')\n",
    "print(f'CPU cores detectados: {cpu_count()}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "step2"},
   "source": ["## 2. Helpers de carga de datos por etapa"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "helpers"},
   "source": [
    "def _load_csv_dir(directory, nrows=None):\n",
    "    \"\"\"Carga todos los CSV de un directorio y los concatena.\"\"\"\n",
    "    files = glob.glob(f'{directory}/*.csv')\n",
    "    if not files:\n",
    "        print(f'  [WARN] No se encontraron CSV en: {directory}')\n",
    "        return pd.DataFrame()\n",
    "    dfs = []\n",
    "    for f in files:\n",
    "        try:\n",
    "            dfs.append(pd.read_csv(f, nrows=nrows))\n",
    "        except Exception as e:\n",
    "            print(f'  [WARN] Error leyendo {f}: {e}')\n",
    "    return pd.concat(dfs, ignore_index=True) if dfs else pd.DataFrame()\n",
    "\n",
    "\n",
    "def _load_single_csv(path):\n",
    "    \"\"\"Carga un único CSV.\"\"\"\n",
    "    try:\n",
    "        return pd.read_csv(path)\n",
    "    except Exception as e:\n",
    "        print(f'  [WARN] No se pudo leer {path}: {e}')\n",
    "        return pd.DataFrame()\n",
    "\n",
    "\n",
    "def _find_model_pkl_and_metadata(models_dir):\n",
    "    \"\"\"Encuentra el .pkl y .json del modelo más reciente.\"\"\"\n",
    "    from datetime import datetime\n",
    "    latest_folder = None\n",
    "    latest_ts = None\n",
    "    for item in os.listdir(models_dir):\n",
    "        item_path = os.path.join(models_dir, item)\n",
    "        if os.path.isdir(item_path):\n",
    "            try:\n",
    "                ts = datetime.strptime(item, '%Y-%m-%d_%H-%M-%S')\n",
    "                if latest_ts is None or ts > latest_ts:\n",
    "                    latest_ts = ts\n",
    "                    latest_folder = item_path\n",
    "            except ValueError:\n",
    "                pass\n",
    "    if latest_folder is None:\n",
    "        print(f'  [WARN] No se encontró modelo en {models_dir}')\n",
    "        return None, None\n",
    "    pkl_files  = glob.glob(f'{latest_folder}/*.pkl')\n",
    "    json_files = glob.glob(f'{latest_folder}/*.json')\n",
    "    return (pkl_files[0]  if pkl_files  else None,\n",
    "            json_files[0] if json_files else None)\n",
    "\n",
    "print('✅ Helpers definidos')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "step3"},
   "source": ["## 3. Definición de Tasks Prefect — Monitoreo"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "tasks_drift"},
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# TASKS DE DRIFT POR ETAPA\n",
    "# Cada task corre independientemente y puede ejecutarse en paralelo\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "@task(name='drift-raw-data', log_prints=True)\n",
    "def compute_raw_drift(payload):\n",
    "    \"\"\"Calcula PSI sobre los datos crudos (etapa RAW).\"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'[Task] Drift RAW — partición {p[\"partition\"]}')\n",
    "    df_actual = _load_csv_dir(payload['DIR_RAWDATA'])\n",
    "    df_ref    = _load_csv_dir(payload['DIR_REF_RAWDATA'])\n",
    "    if df_actual.empty or df_ref.empty:\n",
    "        print('  [SKIP] Datos insuficientes para drift RAW')\n",
    "        return {'stage': 'raw', 'mean_drift': 0, 'n_alerts': 0,\n",
    "                'n_warns': 0, 'n_features': 0, 'metric': p['dd_metric'],\n",
    "                'drift_df': pd.DataFrame(), 'max_drift': 0,\n",
    "                'timestamp': ''}\n",
    "    return mon.compute_stage_drift(\n",
    "        'raw', df_ref, df_actual,\n",
    "        dd_metric=p['dd_metric'],\n",
    "        quantils=p['quantils'],\n",
    "        n_workers=p['n_workers'])\n",
    "\n",
    "\n",
    "@task(name='drift-preprocessed', log_prints=True)\n",
    "def compute_preprocessed_drift(payload):\n",
    "    \"\"\"Calcula PSI sobre los datos preprocesados.\"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'[Task] Drift PREPROCESSED — partición {p[\"partition\"]}')\n",
    "\n",
    "    part  = p['partition']\n",
    "    mname = p['model_name']\n",
    "\n",
    "    actual_path = f\"{payload['DIR_PROCESSED']}/preprocessed/vars_{part}_{mname}.csv\"\n",
    "    df_actual   = _load_single_csv(actual_path)\n",
    "    df_ref      = _load_csv_dir(f\"{payload['DIR_REF_PROCESSED']}/preprocessed\")\n",
    "\n",
    "    if df_actual.empty or df_ref.empty:\n",
    "        print('  [SKIP] Datos insuficientes para drift PREPROCESSED')\n",
    "        return {'stage': 'preprocessed', 'mean_drift': 0, 'n_alerts': 0,\n",
    "                'n_warns': 0, 'n_features': 0, 'metric': p['dd_metric'],\n",
    "                'drift_df': pd.DataFrame(), 'max_drift': 0,\n",
    "                'timestamp': ''}\n",
    "    return mon.compute_stage_drift(\n",
    "        'preprocessed', df_ref, df_actual,\n",
    "        dd_metric=p['dd_metric'],\n",
    "        quantils=p['quantils'],\n",
    "        n_workers=p['n_workers'])\n",
    "\n",
    "\n",
    "@task(name='drift-score-puro', log_prints=True)\n",
    "def compute_score_drift(payload):\n",
    "    \"\"\"Calcula PSI sobre los scores puros (salida de inference.py).\"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'[Task] Drift SCORE PURO — partición {p[\"partition\"]}')\n",
    "\n",
    "    part  = p['partition']\n",
    "    mname = p['model_name']\n",
    "\n",
    "    actual_path = f\"{payload['SCORE_DIR']}/inference_{mname}_{part}.csv\"\n",
    "    df_actual   = _load_single_csv(actual_path)\n",
    "    df_ref      = _load_csv_dir(payload['DIR_REF_SCORES'])\n",
    "\n",
    "    if df_actual.empty or df_ref.empty:\n",
    "        print('  [SKIP] Datos insuficientes para drift SCORE')\n",
    "        return {'stage': 'score_puro', 'mean_drift': 0, 'n_alerts': 0,\n",
    "                'n_warns': 0, 'n_features': 0, 'metric': p['dd_metric'],\n",
    "                'drift_df': pd.DataFrame(), 'max_drift': 0,\n",
    "                'timestamp': ''}\n",
    "    return mon.compute_stage_drift(\n",
    "        'score_puro', df_ref, df_actual,\n",
    "        dd_metric=p['dd_metric'],\n",
    "        quantils=p['quantils'],\n",
    "        n_workers=p['n_workers'])\n",
    "\n",
    "\n",
    "@task(name='drift-score-posprocesado', log_prints=True)\n",
    "def compute_postprocessed_drift(payload):\n",
    "    \"\"\"Calcula PSI sobre los scores posprocesados (puntuacion_tlv, grupo_ejec_tlv, etc.).\"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'[Task] Drift POSPROCESADO — partición {p[\"partition\"]}')\n",
    "\n",
    "    part  = p['partition']\n",
    "    mname = p['model_name']\n",
    "\n",
    "    actual_path = f\"{payload['DIR_OUTPUT']}/scr_{mname}_{part}.txt\"\n",
    "    try:\n",
    "        df_actual = pd.read_csv(actual_path, sep='|')\n",
    "    except Exception as e:\n",
    "        print(f'  [WARN] No se pudo leer posprocesado: {e}')\n",
    "        df_actual = pd.DataFrame()\n",
    "\n",
    "    ref_files = glob.glob(f\"{payload['DIR_REF_OUTPUT']}/*.txt\")\n",
    "    df_ref_list = []\n",
    "    for rf in ref_files:\n",
    "        try:\n",
    "            df_ref_list.append(pd.read_csv(rf, sep='|'))\n",
    "        except Exception:\n",
    "            pass\n",
    "    df_ref = pd.concat(df_ref_list, ignore_index=True) if df_ref_list else pd.DataFrame()\n",
    "\n",
    "    if df_actual.empty or df_ref.empty:\n",
    "        print('  [SKIP] Datos insuficientes para drift POSPROCESADO')\n",
    "        return {'stage': 'score_posprocesado', 'mean_drift': 0, 'n_alerts': 0,\n",
    "                'n_warns': 0, 'n_features': 0, 'metric': p['dd_metric'],\n",
    "                'drift_df': pd.DataFrame(), 'max_drift': 0,\n",
    "                'timestamp': ''}\n",
    "    return mon.compute_stage_drift(\n",
    "        'score_posprocesado', df_ref, df_actual,\n",
    "        dd_metric=p['dd_metric'],\n",
    "        quantils=p['quantils'],\n",
    "        n_workers=p['n_workers'])\n",
    "\n",
    "print('✅ Tasks de drift definidos')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {"id": "tasks_shap"},
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# TASKS DE SHAP\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "@task(name='compute-shap', log_prints=True)\n",
    "def compute_shap_task(payload):\n",
    "    \"\"\"\n",
    "    Calcula SHAP importance para el período actual.\n",
    "    Usa paralelismo CPU (ProcessPoolExecutor) internamente.\n",
    "    \"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'[Task] SHAP Importance — partición {p[\"partition\"]} con {p[\"n_workers\"]} workers')\n",
    "\n",
    "    model_path, meta_path = _find_model_pkl_and_metadata(payload['MODEL_DIR'])\n",
    "    if model_path is None:\n",
    "        print('  [SKIP] No se encontró modelo para SHAP')\n",
    "        return None\n",
    "\n",
    "    with open(meta_path) as f:\n",
    "        metadata = json.load(f)\n",
    "    ml_name = metadata.get('ml_name', 'xgb')\n",
    "\n",
    "    part  = p['partition']\n",
    "    mname = p['model_name']\n",
    "    feat_path = f\"{payload['DIR_PROCESSED']}/preprocessed/vars_{part}_{mname}.csv\"\n",
    "    df_features = _load_single_csv(feat_path)\n",
    "\n",
    "    if df_features.empty:\n",
    "        print('  [SKIP] No se encontraron features para SHAP')\n",
    "        return None\n",
    "\n",
    "    # Quitar target si es la primera columna\n",
    "    target_col = df_features.columns[0]\n",
    "    if target_col in ('target', 'label', 'y'):\n",
    "        df_features = df_features.drop(columns=[target_col])\n",
    "\n",
    "    shap_series = mon.compute_shap_importance(\n",
    "        model_path  = model_path,\n",
    "        ml_name     = ml_name,\n",
    "        df_features = df_features,\n",
    "        n_workers   = p['n_workers'],\n",
    "        sample_size = p.get('shap_sample', 500)\n",
    "    )\n",
    "\n",
    "    print(f'  → Top 5 SHAP features: {list(shap_series.head().index)}')\n",
    "    return shap_series\n",
    "\n",
    "\n",
    "@task(name='update-shap-history', log_prints=True)\n",
    "def update_shap_history(shap_series, payload):\n",
    "    \"\"\"Actualiza el historial SHAP con el período actual y calcula variación.\"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'[Task] Actualizando historial SHAP — partición {p[\"partition\"]}')\n",
    "\n",
    "    history_path = payload['SHAP_HISTORY_PATH']\n",
    "    history = mon.load_shap_history(history_path)\n",
    "\n",
    "    if shap_series is not None and len(shap_series) > 0:\n",
    "        history[str(p['partition'])] = shap_series.to_dict()\n",
    "        mon.save_shap_history(history, history_path)\n",
    "\n",
    "    shap_variation = mon.compute_shap_variation(history)\n",
    "    if len(shap_variation) > 0:\n",
    "        print(f'  → Top variación SHAP: {shap_variation[\"variation_pct\"].abs().head(3).to_dict()}')\n",
    "    return history, shap_variation\n",
    "\n",
    "\n",
    "print('✅ Tasks SHAP definidos')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {"id": "tasks_output"},
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# TASKS DE PERSISTENCIA Y DASHBOARD\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "@task(name='save-monitoring-results', log_prints=True)\n",
    "def save_results_task(stage_summaries, shap_series, shap_variation, payload):\n",
    "    \"\"\"Persiste todos los resultados de monitoreo en disco.\"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'[Task] Guardando resultados — partición {p[\"partition\"]}')\n",
    "    mon.save_monitoring_results(\n",
    "        stage_summaries = stage_summaries,\n",
    "        shap_series     = shap_series,\n",
    "        shap_variation  = shap_variation,\n",
    "        partition       = p['partition'],\n",
    "        output_dir      = payload['MONITORING_DIR']\n",
    "    )\n",
    "\n",
    "\n",
    "@task(name='generate-dashboard', log_prints=True)\n",
    "def generate_dashboard_task(stage_summaries, shap_series, shap_variation,\n",
    "                             shap_history, payload):\n",
    "    \"\"\"Genera el tablero de control HTML interactivo.\"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'[Task] Generando Dashboard — partición {p[\"partition\"]}')\n",
    "    dashboard_path = mon.generate_dashboard(\n",
    "        stage_summaries = stage_summaries,\n",
    "        shap_series     = shap_series,\n",
    "        shap_variation  = shap_variation,\n",
    "        shap_history    = shap_history,\n",
    "        partition       = p['partition'],\n",
    "        output_dir      = payload['MONITORING_DIR']\n",
    "    )\n",
    "    return dashboard_path\n",
    "\n",
    "\n",
    "print('✅ Tasks de persistencia y dashboard definidos')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "step4"},
   "source": ["## 4. Flow principal: `monitoring_pipeline`"]
  },
  {
   "cell_type": "code",
   "metadata": {"id": "flow_main"},
   "source": [
    "@flow(name='monitoring-pipeline', log_prints=True)\n",
    "def monitoring_pipeline(payload):\n",
    "    \"\"\"\n",
    "    Pipeline de monitoreo E2E con Prefect.\n",
    "\n",
    "    Estrategia de paralelismo\n",
    "    ─────────────────────────\n",
    "    Las 4 tasks de drift se lanzan con .submit() para ejecutarse\n",
    "    en paralelo (Prefect ConcurrentTaskRunner por defecto en Colab).\n",
    "    Dentro de cada task, monitoring_utils usa ProcessPoolExecutor\n",
    "    con N_WORKERS >= 2 para distribuir el cálculo por columnas.\n",
    "    \"\"\"\n",
    "    p = payload['params']\n",
    "    print(f'\\n{'='*60}')\n",
    "    print(f'  MONITORING PIPELINE — Partición {p[\"partition\"]}')\n",
    "    print(f'  Métrica: {p[\"dd_metric\"]} | Workers: {p[\"n_workers\"]}')\n",
    "    print(f'{'='*60}\\n')\n",
    "\n",
    "    # ── FASE 1: Drift en paralelo (4 etapas simultáneas) ──────────────────\n",
    "    print('[Flow] Lanzando tasks de drift en paralelo...')\n",
    "    raw_future   = compute_raw_drift.submit(payload)\n",
    "    prep_future  = compute_preprocessed_drift.submit(payload)\n",
    "    score_future = compute_score_drift.submit(payload)\n",
    "    post_future  = compute_postprocessed_drift.submit(payload)\n",
    "\n",
    "    # Recolectar resultados\n",
    "    raw_summary   = raw_future.result()\n",
    "    prep_summary  = prep_future.result()\n",
    "    score_summary = score_future.result()\n",
    "    post_summary  = post_future.result()\n",
    "\n",
    "    stage_summaries = [raw_summary, prep_summary, score_summary, post_summary]\n",
    "    print('[Flow] ✅ Drift calculado en las 4 etapas del pipeline')\n",
    "\n",
    "    # ── FASE 2: SHAP importance ───────────────────────────────────────────\n",
    "    print('[Flow] Calculando SHAP importance...')\n",
    "    shap_series = compute_shap_task(payload)\n",
    "\n",
    "    # ── FASE 3: Historial SHAP y variación mes a mes ──────────────────────\n",
    "    shap_history, shap_variation = update_shap_history(shap_series, payload)\n",
    "    print('[Flow] ✅ Historial SHAP actualizado')\n",
    "\n",
    "    # ── FASE 4: Persistencia ──────────────────────────────────────────────\n",
    "    save_results_task(stage_summaries, shap_series, shap_variation, payload)\n",
    "\n",
    "    # ── FASE 5: Dashboard ─────────────────────────────────────────────────\n",
